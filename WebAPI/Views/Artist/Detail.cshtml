@model BepopStreamProject.Models.ArtistDetailViewModel
@using BepopStreamProject.Helpers
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userLevel = User.GetUserLevel();
    string heroImg = string.IsNullOrEmpty(Model.ImageUrl) ? "/Bebop/assets/img/b6.jpg" : Model.ImageUrl;
}

@section Styles {
    <link rel="stylesheet" href="~/Bebop/assets/css/artist-detail.css" asp-append-version="true" />
}

<div class="artist-page">

    <!-- HERO -->
    <div class="artist-hero fade-up">
        <div class="artist-hero-bg" style="background-image:url('@heroImg')"></div>
        <div class="artist-hero-overlay"></div>
        <div class="artist-hero-content">
            <div class="artist-avatar" style="background-image:url('@heroImg')"></div>
            <div class="artist-info">
                <div class="artist-verified">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" /></svg>
                    Sanatçı
                </div>
                <h1 class="artist-name">@Model.Name</h1>
                <div class="artist-stats-row">
                    @if (!string.IsNullOrEmpty(Model.Country))
                    {
                        <span class="artist-stat">📍 @Model.Country</span>
                        <span style="color:rgba(255,255,255,0.2)">·</span>
                    }
                    <span class="artist-stat"><strong>@Model.Songs.Count</strong> şarkı</span>
                    <span style="color:rgba(255,255,255,0.2)">·</span>
                    <span class="artist-stat"><strong>@Model.Albums.Count</strong> albüm</span>
                    <span style="color:rgba(255,255,255,0.2)">·</span>
                    <span class="artist-stat"><strong>@Model.FollowersCount.ToString("N0")</strong> takipçi</span>
                </div>
                <div class="artist-actions">
                    <form asp-action="ToggleFollow" asp-controller="Artist" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.ArtistId" />
                        @if (Model.IsFollowing)
                        {
                            <button type="submit" class="btn-unfollow">Takibi Bırak</button>
                        }
                        else
                        {
                            <button type="submit" class="btn-follow">Takip Et</button>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- BODY -->
    <div class="artist-body fade-up delay-1">

        <!-- TABS -->
        <div class="artist-tabs">
            <button class="artist-tab active" onclick="switchTab('tracks', this)">Şarkılar</button>
            <button class="artist-tab" onclick="switchTab('albums', this)">Albümler</button>
        </div>

        <!-- TRACKS -->
        <div class="tab-content-panel active" id="tab-tracks">
            <div class="tracks-table">
                @{
                    int i = 1;
                }
                @foreach (var song in Model.Songs)
                {
                    string imgUrl = string.IsNullOrEmpty(song.ImageUrl) ? "/Bebop/assets/img/b6.jpg" : song.ImageUrl;
                    bool locked = userLevel < song.Level;
                    string lvlName = song.Level switch { 1 => "Ücretsiz", 2 => "Gold", 3 => "Premium", _ => "" };
                    <div class="track-row">
                        <div class="track-num">@i</div>
                        <div class="track-cover" style="background-image:url('@imgUrl');width:44px;height:44px;min-width:44px;border-radius:8px;background-size:cover;background-position:center;background-color:#2a2a2a;"></div>
                        <div class="track-info">
                            <div class="track-title">
                                <a href="@Url.Action("Details", "Songs", new { id = song.SongId })">@song.Title</a>
                            </div>
                            @if (!string.IsNullOrEmpty(song.ImageUrl))
                            {
                                <div class="track-album">@Model.Name</div>
                            }
                        </div>
                        <div class="track-level">
                            @if (song.Level > 1)
                            {
                                <span class="level-badge level-@song.Level" style="font-size:10px;padding:2px 8px;">@lvlName</span>
                            }
                        </div>
                        <div>
                            @if (!locked)
                            {
                                <button class="track-play-btn btn-play" data-id="@song.SongId" data-source="@song.FileUrl" title="Çal">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="6,3 20,12 6,21" /></svg>
                                </button>
                            }
                            else
                            {
                                <button class="track-play-btn track-locked" disabled title="@lvlName üyeliği gerekli">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                                </button>
                            }
                        </div>
                    </div>
                    i++;
                }
            </div>
        </div>

        <!-- ALBUMS -->
        <div class="tab-content-panel" id="tab-albums">
            <div class="albums-grid">
                @foreach (var album in Model.Albums)
                {
                    string albumImg = string.IsNullOrEmpty(album.CoverImageUrl) ? "/Bebop/assets/img/b6.jpg" : album.CoverImageUrl;
                    <a href="@Url.Action("Details", "Albums", new { id = album.AlbumId })" class="album-card">
                        <div class="album-art" style="background-image:url('@albumImg')"></div>
                        <div class="album-title">@album.Title</div>
                        <div class="album-year">@album.ReleaseDate.Year</div>
                    </a>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function switchTab(name, btn) {
            document.querySelectorAll('.tab-content-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.artist-tab').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + name).classList.add('active');
            btn.classList.add('active');
        }
    </script>
}