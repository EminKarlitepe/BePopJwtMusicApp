@model Core.Entities.Genre
@{
    ViewData["Title"] = "Yeni Tür Ekle";
    ViewData["Active"] = "Genres";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card card-primary" style="max-width:500px;">
    <div class="card-header">
        <h3 class="card-title">Tür Bilgileri</h3>
    </div>
    <form asp-action="CreateGenre" method="post">
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <div class="form-group">
                <label>Tür Adı *</label>
                <input asp-for="Name" class="form-control" placeholder="Örn: Pop, Rock, Hip-Hop" />
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Kaydet
            </button>
            <a href="/Admin/Genres" class="btn btn-secondary ml-2">
                <i class="fas fa-times"></i> İptal
            </a>
        </div>
    </form>
</div>