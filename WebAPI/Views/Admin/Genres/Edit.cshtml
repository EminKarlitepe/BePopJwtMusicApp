@model Core.Entities.Genre
@{
    ViewData["Title"] = "Tür Düzenle";
    ViewData["Active"] = "Genres";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card card-warning" style="max-width:500px;">
    <div class="card-header">
        <h3 class="card-title">Tür Bilgilerini Güncelle</h3>
    </div>
    <form asp-action="EditGenre" method="post">
        <input type="hidden" asp-for="GenreId" />
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <div class="form-group">
                <label>Tür Adı *</label>
                <input asp-for="Name" class="form-control" />
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-save"></i> Güncelle
            </button>
            <a href="/Admin/Genres" class="btn btn-secondary ml-2">
                <i class="fas fa-times"></i> İptal
            </a>
        </div>
    </form>
</div>