@model List<Core.Entities.Genre>
@{
    ViewData["Title"] = "Tür Yönetimi";
    ViewData["Active"] = "Genres";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span>Toplam @Model.Count tür</span>
    <a href="/Admin/CreateGenre" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Tür Ekle
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>#</th>
                    <th>Tür Adı</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var genre in Model)
                {
                    <tr>
                        <td>@genre.GenreId</td>
                        <td>@genre.Name</td>
                        <td>
                            <a href="/Admin/EditGenre/@genre.GenreId" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i> Düzenle
                            </a>
                            <form action="/Admin/DeleteGenre/@genre.GenreId" method="post" style="display:inline;"
                                  onsubmit="return confirm('Bu türü silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>