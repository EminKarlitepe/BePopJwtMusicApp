@model Core.Entities.Chart
@{
    ViewData["Title"] = "Chart Düzenle";
    ViewData["Active"] = "Charts";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card card-warning" style="max-width:700px;">
    <div class="card-header">
        <h3 class="card-title">Chart Bilgilerini Güncelle</h3>
    </div>
    <form asp-action="EditChart" method="post">
        <input type="hidden" asp-for="ChartId" />
        <input type="hidden" asp-for="CreatedAt" />
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <div class="form-group">
                <label>Chart Adı *</label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="form-group">
                <label>Ülke</label>
                <input asp-for="Country" class="form-control" />
            </div>
            <div class="form-group">
                <label>Tür</label>
                <input asp-for="Genre" class="form-control" />
            </div>
            <div class="form-group">
                <label>Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-save"></i> Güncelle
            </button>
            <a href="/Admin/Charts" class="btn btn-secondary ml-2">
                <i class="fas fa-times"></i> İptal
            </a>
        </div>
    </form>
</div>