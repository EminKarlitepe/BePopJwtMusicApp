@model List<Core.Entities.Chart>
@{
    ViewData["Title"] = "Chart Yönetimi";
    ViewData["Active"] = "Charts";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span>Toplam @Model.Count chart</span>
    <a href="/Admin/CreateChart" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Chart Ekle
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>#</th>
                    <th>Ad</th>
                    <th>Ülke</th>
                    <th>Tür</th>
                    <th>Açıklama</th>
                    <th>Tarih</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var chart in Model)
                {
                    <tr>
                        <td>@chart.ChartId</td>
                        <td>@chart.Name</td>
                        <td>@(chart.Country ?? "-")</td>
                        <td>@(chart.Genre ?? "-")</td>
                        <td>@(chart.Description?.Length > 50 ? chart.Description.Substring(0, 50) + "..." : chart.Description ?? "-")</td>
                        <td>@chart.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a href="/Admin/EditChart/@chart.ChartId" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i> Düzenle
                            </a>
                            <form action="/Admin/DeleteChart/@chart.ChartId" method="post" style="display:inline;"
                                  onsubmit="return confirm('Bu chartı silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>