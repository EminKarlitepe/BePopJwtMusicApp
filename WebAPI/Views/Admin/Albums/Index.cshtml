@model List<Core.Entities.Album>
@{
    ViewData["Title"] = "Albüm Yönetimi";
    ViewData["Active"] = "Albums";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span>Toplam @Model.Count albüm</span>
    <a href="/Admin/CreateAlbum" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Albüm Ekle
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>#</th>
                    <th>Kapak</th>
                    <th>Albüm Adı</th>
                    <th>Sanatçı</th>
                    <th>Çıkış Tarihi</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var album in Model)
                {
                    <tr>
                        <td>@album.AlbumId</td>
                        <td>
                            @if (!string.IsNullOrEmpty(album.CoverImageUrl))
                            {
                                <img src="@album.CoverImageUrl" width="50" height="50"
                                     style="object-fit:cover; border-radius:4px;" />
                            }
                            else
                            {
                                <span class="badge badge-secondary">Yok</span>
                            }
                        </td>
                        <td>@album.Title</td>
                        <td>@(album.Artist?.Name ?? "-")</td>
                        <td>@album.ReleaseDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a href="/Admin/EditAlbum/@album.AlbumId" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i> Düzenle
                            </a>
                            <form action="/Admin/DeleteAlbum/@album.AlbumId" method="post" style="display:inline;"
                                  onsubmit="return confirm('Bu albümü silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>