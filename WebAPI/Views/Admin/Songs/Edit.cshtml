@model Core.Entities.Song
@{
    ViewData["Title"] = "Şarkı Düzenle";
    ViewData["Active"] = "Songs";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var artists = ViewBag.Artists as List<Core.Entities.Artist>;
    var albums = ViewBag.Albums as List<Core.Entities.Album>;
    var genres = ViewBag.Genres as List<Core.Entities.Genre>;
    var selectedGenres = ViewBag.SelectedGenres as List<int> ?? new List<int>();
}

<div class="card card-warning" style="max-width:700px;">
    <div class="card-header">
        <h3 class="card-title">Şarkı Bilgilerini Güncelle</h3>
    </div>
    <form asp-action="EditSong" method="post">
        <input type="hidden" asp-for="SongId" />
        <input type="hidden" asp-for="CreatedAt" />
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <div class="form-group">
                <label>Şarkı Adı *</label>
                <input asp-for="Title" class="form-control" />
            </div>
            <div class="form-group position-relative">
                <label>Sanatçı *</label>
                <input type="text" id="artistSearch" name="artistName" class="form-control" placeholder="Sanatçı adı yazın" autocomplete="off" value="@(Model.Artist?.Name ?? "")" />
                <input asp-for="ArtistId" type="hidden" id="ArtistId" />
                <div id="artistResults" class="list-group position-absolute" style="z-index:1050; width:100%; display:none; max-height:220px; overflow:auto; box-shadow:0 2px 6px rgba(0,0,0,.15);">
                </div>
            </div>
            <div class="form-group position-relative">
                <label>Albüm</label>
                <input type="text" id="albumSearch" class="form-control" placeholder="Albüm adı yazın" autocomplete="off" value="@(Model.Album?.Title ?? "")" />
                <input asp-for="AlbumId" type="hidden" id="AlbumId" />
                <div id="albumResults" class="list-group position-absolute" style="z-index:1050; width:100%; display:none; max-height:220px; overflow:auto; box-shadow:0 2px 6px rgba(0,0,0,.15);">
                </div>
            </div>
            <div class="form-group">
                <label>Dosya URL *</label>
                <input asp-for="FileUrl" class="form-control" />
            </div>
            <div class="form-group">
                <label>Albüm Kapak URL</label>
                <input asp-for="AlbumCoverUrl" class="form-control" />
            </div>
            <div class="form-group">
                <label>Seviye</label>
                <select asp-for="Level" class="form-control">
                    <option value="1" selected="@(Model.Level == 1)">Ücretsiz</option>
                    <option value="2" selected="@(Model.Level == 2)">Gold</option>
                    <option value="3" selected="@(Model.Level == 3)">Premium</option>
                </select>
            </div>
            <div class="form-group">
                <label>Türler</label>
                <div class="row">
                    @foreach (var genre in genres)
                    {
                        <div class="col-md-4">
                            <div class="form-check">
                                @if (selectedGenres.Contains(genre.GenreId))
                                {
                                    <input type="checkbox" name="genreIds" value="@genre.GenreId"
                                           class="form-check-input" id="genre_@genre.GenreId" checked />
                                }
                                else
                                {
                                    <input type="checkbox" name="genreIds" value="@genre.GenreId"
                                           class="form-check-input" id="genre_@genre.GenreId" />
                                }
                                <label class="form-check-label" for="genre_@genre.GenreId">@genre.Name</label>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-save"></i> Güncelle
            </button>
            <a href="/Admin/Songs" class="btn btn-secondary ml-2">
                <i class="fas fa-times"></i> İptal
            </a>
        </div>
    </form>
</div>