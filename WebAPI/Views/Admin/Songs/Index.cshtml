@model List<Core.Entities.Song>
@{
    ViewData["Title"] = "Şarkı Yönetimi";
    ViewData["Active"] = "Songs";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span>Toplam @Model.Count şarkı</span>
    <a href="/Admin/UploadSong" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Şarkı Ekle
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>#</th>
                    <th>Kapak</th>
                    <th>Şarkı Adı</th>
                    <th>Sanatçı</th>
                    <th>Albüm</th>
                    <th>Seviye</th>
                    <th>Tarih</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var song in Model)
                {
                    <tr>
                        <td>@song.SongId</td>
                        <td>
                            @if (!string.IsNullOrEmpty(song.AlbumCoverUrl))
                            {
                                <img src="@song.AlbumCoverUrl" width="50" height="50"
                                     style="object-fit:cover; border-radius:4px;" />
                            }
                            else
                            {
                                <span class="badge badge-secondary">Yok</span>
                            }
                        </td>
                        <td>@song.Title</td>
                        <td>@(song.Artist?.Name ?? "-")</td>
                        <td>@(song.Album?.Title ?? "-")</td>
                        <td>
                            @if (song.Level == 1)
                            {
                                <span class="badge badge-success">Ücretsiz</span>
                            }
                            else if (song.Level == 2)
                            {
                                <span class="badge badge-warning">Gold</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Premium</span>
                            }
                        </td>
                        <td>@song.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a href="/Admin/EditSong/@song.SongId" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i> Düzenle
                            </a>
                            <a href="/Admin/EditSong/@song.SongId" class="btn btn-sm btn-primary ml-1" title="Güncelle">
                                <i class="fas fa-sync-alt"></i> Güncelle
                            </a>
                            <a href="/Admin/AssignGenres/@song.SongId" class="btn btn-sm btn-info ml-1" title="Türleri Ata">
                                <i class="fas fa-tags"></i> Türleri Ata
                            </a>
                            <form action="/Admin/DeleteSong/@song.SongId" method="post" style="display:inline;"
                                  onsubmit="return confirm('Bu şarkıyı silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>