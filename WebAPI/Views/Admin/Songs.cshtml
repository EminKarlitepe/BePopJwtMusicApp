@model List<BepopStreamProject.Models.SongViewModel>
@{
    ViewData["Title"] = "Şarkı Yönetimi";
    ViewData["Active"] = "Songs";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int total = ViewBag.TotalSongs ?? 0;
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 20;
    int totalPages = (int)Math.Ceiling((double)total / pageSize);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span>Toplam <strong>@total</strong> şarkı</span>
    <a href="/Admin/UploadSong" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Şarkı Ekle
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>#</th>
                    <th>Kapak</th>
                    <th>Şarkı Adı</th>
                    <th>Sanatçı</th>
                    <th>Seviye</th>
                    <th>URL</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var song in Model)
                {
                    <tr>
                        <td>@song.SongId</td>
                        <td>
                            @if (!string.IsNullOrEmpty(song.ImageUrl))
                            {
                                <img src="@song.ImageUrl" width="50" height="50"
                                     style="border-radius:6px; object-fit:cover;" />
                            }
                            else
                            {
                                <span class="badge badge-secondary">Yok</span>
                            }
                        </td>
                        <td><strong>@song.Title</strong></td>
                        <td>@(song.ArtistName ?? "-")</td>
                        <td>
                            @{
                                var badgeClass = song.Level switch
                                {
                                    1 => "badge-success",
                                    2 => "badge-warning",
                                    3 => "badge-danger",
                                    _ => "badge-light"
                                };
                                var levelName = song.Level switch
                                {
                                    1 => "Ücretsiz",
                                    2 => "Gold",
                                    3 => "Premium",
                                    _ => "-"
                                };
                            }
                            <span class="badge @badgeClass">@levelName</span>
                        </td>
                        <td>
                            <small class="text-muted" title="@song.FileUrl">
                                @(song.FileUrl?.Length > 40 ? song.FileUrl.Substring(0, 40) + "..." : song.FileUrl ?? "-")
                            </small>
                        </td>
                        <td>
                            <a href="/Songs/Details/@song.SongId" target="_blank" class="btn btn-sm btn-info">
                                <i class="fas fa-eye"></i> Görüntüle
                            </a>
                            <a href="/Admin/EditSong/@song.SongId" class="btn btn-sm btn-primary ml-1" title="Güncelle">
                                <i class="fas fa-sync-alt"></i> Güncelle
                            </a>
                            <form action="/Admin/DeleteSong/@song.SongId" method="post" style="display:inline;"
                                  onsubmit="return confirm('@song.Title şarkısını silmek istediğinize emin misiniz?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="card-footer clearfix">
            <ul class="pagination pagination-sm m-0 float-right">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link" href="/Admin/Songs?page=@i">@i</a>
                    </li>
                }
            </ul>
        </div>
    }
</div>