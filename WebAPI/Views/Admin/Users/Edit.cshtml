@model Core.Entities.User
@{
    ViewData["Title"] = "Kullanıcı Düzenle";
    ViewData["Active"] = "Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var roles = ViewBag.Roles as List<Core.Entities.Role>;
}
<div class="card card-warning" style="max-width:700px;">
    <div class="card-header">
        <h3 class="card-title">Kullanıcı Bilgilerini Güncelle</h3>
    </div>
    <form asp-action="EditUser" method="post">
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="PasswordHash" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="Uid" />
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
            {
                <div class="text-center mb-3">
                    <img src="@Model.ProfileImageUrl" width="80" height="80"
                         style="border-radius:50%; object-fit:cover; border:3px solid #ffc107;" />
                </div>
            }
            <div class="form-group">
                <label>Kullanıcı Adı</label>
                <input asp-for="Username" class="form-control" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" class="form-control" />
            </div>
            <div class="form-group">
                <label>Display Name</label>
                <input asp-for="DisplayName" class="form-control" />
            </div>
            <div class="form-group">
                <label>Ülke</label>
                <input asp-for="Country" class="form-control" />
            </div>
            <div class="form-group">
                <label>Bio</label>
                <textarea asp-for="Bio" class="form-control" rows="3"></textarea>
            </div>
            <div class="form-group">
                <label>Üyelik Seviyesi</label>
                <select asp-for="MembershipLevel" class="form-control">
                    <option value="1">Ücretsiz</option>
                    <option value="2">Gold</option>
                    <option value="3">Premium</option>
                </select>
            </div>
            <div class="form-group">
                <label>Rol</label>
                <select name="roleId" class="form-control">
                    @foreach (var role in roles)
                    {
                        <option value="@role.RoleId">@role.Name</option>
                    }
                </select>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-save"></i> Güncelle
            </button>
            <a href="/Admin/Users" class="btn btn-secondary ml-2">
                <i class="fas fa-times"></i> İptal
            </a>
        </div>
    </form>
</div>