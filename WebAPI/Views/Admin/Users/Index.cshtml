@model List<Core.Entities.User>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
    ViewData["Active"] = "Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span>Toplam @Model.Count kullanıcı</span>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>#</th>
                    <th>Fotoğraf</th>
                    <th>Kullanıcı Adı</th>
                    <th>Email</th>
                    <th>Üyelik</th>
                    <th>Kayıt Tarihi</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.UserId</td>
                        <td>
                            @if (!string.IsNullOrEmpty(user.ProfileImageUrl))
                            {
                                <img src="@user.ProfileImageUrl" width="40" height="40"
                                     style="border-radius:50%; object-fit:cover;" />
                            }
                            else
                            {
                                <span class="badge badge-secondary">Yok</span>
                            }
                        </td>
                        <td>@user.Username</td>
                        <td>@user.Email</td>
                        <td>
                            @if (user.MembershipLevel == 1)
                            {
                                <span class="badge badge-secondary">Ücretsiz</span>
                            }
                            else if (user.MembershipLevel == 2)
                            {
                                <span class="badge badge-warning">Gold</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Premium</span>
                            }
                        </td>
                        <td>@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a href="/Admin/EditUser/@user.UserId" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i> Düzenle
                            </a>
                            <form action="/Admin/DeleteUser/@user.UserId" method="post" style="display:inline;"
                                  onsubmit="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>