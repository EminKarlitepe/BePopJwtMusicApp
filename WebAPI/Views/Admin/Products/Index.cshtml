@model List<Core.Entities.Product>
@{
    ViewData["Title"] = "Paket Yönetimi";
    ViewData["Active"] = "Products";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span>Toplam @Model.Count Paket</span>
    <a href="/Admin/CreateProduct" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Paket Ekle
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>#</th>
                    <th>Paket Adı</th>
                    <th>SKU</th>
                    <th>Fiyat</th>
                    <th>Tarih</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.ProductId</td>
                        <td>@product.Name</td>
                        <td>@(product.Sku ?? "-")</td>
                        <td>@product.Price.ToString("C2")</td>
                        <td>@product.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a href="/Admin/EditProduct/@product.ProductId" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i> Düzenle
                            </a>
                            <form action="/Admin/DeleteProduct/@product.ProductId" method="post" style="display:inline;"
                                  onsubmit="return confirm('Bu Paket silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>