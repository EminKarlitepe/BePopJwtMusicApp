@model Core.Entities.Product
@{
    ViewData["Title"] = "Paket Düzenle";
    ViewData["Active"] = "Products";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var categories = ViewBag.Categories as List<Core.Entities.Category>;
}

<div class="card card-warning" style="max-width:700px;">
    <div class="card-header">
        <h3 class="card-title">Paket Bilgilerini Güncelle</h3>
    </div>
    <form asp-action="EditProduct" method="post">
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="CreatedAt" />
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <div class="form-group">
                <label>Pkaet Adı *</label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="form-group">
                <label>SKU</label>
                <input asp-for="Sku" class="form-control" />
            </div>
            <div class="form-group">
                <label>Kategori *</label>
                <select asp-for="CategoryId" class="form-control">
                    <option value="">-- Kategori Seç --</option>
                    @foreach (var category in categories)
                    {
                        if (category.CategoryId == Model.CategoryId)
                        {
                            <option value="@category.CategoryId" selected>@category.Name</option>
                        }
                        else
                        {
                            <option value="@category.CategoryId">@category.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Fiyat *</label>
                <input asp-for="Price" class="form-control" />
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-save"></i> Güncelle
            </button>
            <a href="/Admin/Products" class="btn btn-secondary ml-2">
                <i class="fas fa-times"></i> İptal
            </a>
        </div>
    </form>
</div>