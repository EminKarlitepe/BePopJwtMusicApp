@model Core.Entities.Product
@{
    ViewData["Title"] = "Yeni Paket Ekle";
    ViewData["Active"] = "Products";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var categories = ViewBag.Categories as List<Core.Entities.Category>;
}

<div class="card card-primary" style="max-width:700px;">
    <div class="card-header">
        <h3 class="card-title">Paket Bilgileri</h3>
    </div>
    <form asp-action="CreateProduct" method="post">
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <div class="form-group">
                <label>Paket Adı *</label>
                <input asp-for="Name" class="form-control" placeholder="Paket adını girin" />
            </div>
            <div class="form-group">
                <label>SKU</label>
                <input asp-for="Sku" class="form-control" placeholder="Örn: PRD-001" />
            </div>
            <div class="form-group">
                <label>Kategori *</label>
                <select asp-for="CategoryId" class="form-control">
                    <option value="">-- Kategori Seç --</option>
                    @foreach (var category in categories)
                    {
                        <option value="@category.CategoryId">@category.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Fiyat *</label>
                <input asp-for="Price" class="form-control" placeholder="0.00" />
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Kaydet
            </button>
            <a href="/Admin/Products" class="btn btn-secondary ml-2">
                <i class="fas fa-times"></i> İptal
            </a>
        </div>
    </form>
</div>