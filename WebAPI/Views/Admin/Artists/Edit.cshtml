@model Core.Entities.Artist
@{
    ViewData["Title"] = "Sanatçı Düzenle";
    ViewData["Active"] = "Artists";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card card-warning" style="max-width:700px;">
    <div class="card-header">
        <h3 class="card-title">Sanatçı Bilgilerini Güncelle</h3>
    </div>
    <form asp-action="EditArtist" method="post">
        <input type="hidden" asp-for="ArtistId" />
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
            {
                <div class="text-center mb-3">
                    <img src="@Model.ProfileImageUrl" width="100" height="100"
                         style="border-radius:50%; object-fit:cover; border:3px solid #ffc107;" />
                </div>
            }
            <div class="form-group">
                <label>Sanatçı Adı *</label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="form-group">
                <label>Ülke</label>
                <input asp-for="Country" class="form-control" />
            </div>
            <div class="form-group">
                <label>Profil Fotoğrafı URL</label>
                <input asp-for="ProfileImageUrl" class="form-control" />
            </div>
            <div class="form-group">
                <label>Bio</label>
                <textarea asp-for="Bio" class="form-control" rows="4"></textarea>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-save"></i> Güncelle
            </button>
            <a href="/Admin/Artists" class="btn btn-secondary ml-2">
                <i class="fas fa-times"></i> İptal
            </a>
        </div>
    </form>
</div>