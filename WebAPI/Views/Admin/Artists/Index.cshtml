@model List<Core.Entities.Artist>
@{
    ViewData["Title"] = "Sanatçı Yönetimi";
    ViewData["Active"] = "Artists";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span>Toplam @Model.Count sanatçı</span>
    <a href="/Admin/CreateArtist" class="btn btn-primary">
        <i class="fas fa-plus"></i> Yeni Sanatçı Ekle
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>#</th>
                    <th>Fotoğraf</th>
                    <th>Ad</th>
                    <th>Ülke</th>
                    <th>Bio</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var artist in Model)
                {
                    <tr>
                        <td>@artist.ArtistId</td>
                        <td>
                            @if (!string.IsNullOrEmpty(artist.ProfileImageUrl))
                            {
                                <img src="@artist.ProfileImageUrl" width="50" height="50"
                                     style="border-radius:50%; object-fit:cover;" />
                            }
                            else
                            {
                                <span class="badge badge-secondary">Yok</span>
                            }
                        </td>
                        <td>@artist.Name</td>
                        <td>@(artist.Country ?? "-")</td>
                        <td>@(artist.Bio?.Length > 60 ? artist.Bio.Substring(0, 60) + "..." : artist.Bio ?? "-")</td>
                        <td>
                            <a href="/Admin/EditArtist/@artist.ArtistId" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i> Düzenle
                            </a>
                            <form action="/Admin/DeleteArtist/@artist.ArtistId" method="post" style="display:inline;"
                                  onsubmit="return confirm('Bu sanatçıyı silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Sil
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>